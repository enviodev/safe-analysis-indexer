{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "target": "es2022",
    "lib": ["es2022"],
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "outDir": "build"
  },
  "include": [
    "src"
  ],
  "exclude": [
    "test",
    "build",
    "generated"
  ]
}
