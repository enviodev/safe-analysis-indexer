PORT=4000
DATABASE_URI=postgresql://postgres:testing@localhost:5433/envio-dev

# RPC URL per chain for the indexing endpoint (viem): block timestamps, chain head, synced.
# If unset, currentBlockNumber falls back to source_block, timestamps to ready_at or null, synced = (progress_block >= source_block).
# Set RPC_URL_1 (and others per chain) to get non-null timestamps and head-based synced.
# RPC_URL_1=https://eth.drpc.org
# RPC_URL_137=https://polygon.drpc.org
# RPC_URL_10=https://optimism.drpc.org
# RPC_URL_100=https://gnosis.drpc.org
