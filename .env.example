# To create or update a token visit https://envio.dev/app/api-tokens
ENVIO_API_TOKEN="<YOUR-API-TOKEN>"
# Optional: DRPC API key for RPC trace fallback on chains without HyperSync traces
ENVIO_DRPC_API_KEY=""

# Optional: mirror entities to a ClickHouse sink. With `storage.clickhouse: true`
# in config.yaml, `envio dev` auto-launches a local ClickHouse container if HOST
# is unset. Set HOST to a remote URL to skip the auto-launch.
# ENVIO_CLICKHOUSE_HOST=http://localhost:8123
# ENVIO_CLICKHOUSE_DATABASE=envio
# ENVIO_CLICKHOUSE_USERNAME=envio
# ENVIO_CLICKHOUSE_PASSWORD=envio

# ─── Cross-reference integration suite (`pnpm test:integration`) ─────────────
# Required. The deployed indexer GraphQL endpoint to validate against. There's
# deliberately no default because deployment hashes rotate.
INTEGRATION_INDEXER_ENDPOINT=https://indexer.eu.hyperindex.xyz/<deploy-hash>/v1/graphql

# Optional. Comma-separated chain IDs. Default: 1,100 (Ethereum + Gnosis).
# INTEGRATION_CHAINS=1,100

# Optional. Number of Safes to sample per chain. Default: 10.
# INTEGRATION_SAMPLE_SIZE=10

# Optional. Set to "1" to skip the live preflight ping against the indexer
# (useful for local debugging without network access).
# INTEGRATION_SKIP_PING=0

