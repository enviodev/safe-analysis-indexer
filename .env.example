# To create or update a token visit https://envio.dev/app/api-tokens
ENVIO_API_TOKEN="<YOUR-API-TOKEN>"
# Optional: DRPC API key for RPC trace fallback on chains without HyperSync traces
ENVIO_DRPC_API_KEY=""

# Optional: mirror entities to a local ClickHouse sink (see docker-compose.yml).
# Leave HOST unset to keep the indexer Postgres-only. HOST must be a full URL.
# ENVIO_CLICKHOUSE_SINK_HOST=http://localhost:8123
# ENVIO_CLICKHOUSE_SINK_DATABASE=envio
# ENVIO_CLICKHOUSE_SINK_USERNAME=envio
# ENVIO_CLICKHOUSE_SINK_PASSWORD=envio

